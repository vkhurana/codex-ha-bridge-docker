MQTT_URL=mqtt://homeassistant.local:1883
MQTT_USERNAME=
MQTT_PASSWORD=

# Windows default: C:\Users\<you>\.codex
# macOS/Linux default: ~/.codex
CODEX_HOME=

# Optional. Use this only if the bridge cannot read your Codex auth.json.
CODEX_ACCESS_TOKEN=

# Polling and MQTT topics
POLL_SECONDS=60
MQTT_BASE_TOPIC=codex/usage
HA_DISCOVERY_PREFIX=homeassistant
DEVICE_ID=codex_usage
DEVICE_NAME=Codex Usage
